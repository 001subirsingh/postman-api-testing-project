  "item": [
    {
      "name": "Login API",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson;",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is under 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Content-Type header is JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"Response has valid JSON\", function () {",
              "    responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"Login response contains required top-level fields\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson).to.have.all.keys(\"accessToken\", \"refreshToken\", \"id\", \"username\", \"email\", \"firstName\", \"lastName\", \"gender\", \"image\");",
              "});",
              "",
              "pm.test(\"Tokens are present and are strings\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.accessToken).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.refreshToken).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.test(\"User identity fields have expected types\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.id).to.be.a(\"number\");",
              "    pm.expect(responseJson.username).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.email).to.be.a(\"string\").and.to.include(\"@\");",
              "    pm.expect(responseJson.firstName).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.lastName).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.test(\"Gender and image fields are well-formed\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.gender).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.image).to.be.a(\"string\").and.match(/^https?:\\/\\//);",
              "});",
              "",
              "pm.test(\"Access token appears to be JWT-like\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.accessToken.split(\".\")).to.have.lengthOf(3);",
              "});",
              "",
              "pm.test(\"Save access token to environment\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson).to.have.property(\"accessToken\");",
              "    pm.environment.set(\"token\", responseJson.accessToken);",
              "    console.log(\"Saved token:\", pm.environment.get(\"token\"));",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{  \r\n    \"username\": \"emilys\",\r\n    \"password\": \"emilyspass\"\r\n }",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get User Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson;",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is under 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Content-Type header is JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"Response has valid JSON\", function () {",
              "    responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"Profile contains core identity fields\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson).to.have.property(\"id\");",
              "    pm.expect(responseJson).to.have.property(\"firstName\");",
              "    pm.expect(responseJson).to.have.property(\"lastName\");",
              "    pm.expect(responseJson).to.have.property(\"email\");",
              "    pm.expect(responseJson).to.have.property(\"username\");",
              "});",
              "",
              "pm.test(\"Identity fields have correct data types\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.id).to.be.a(\"number\");",
              "    pm.expect(responseJson.firstName).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.lastName).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.email).to.be.a(\"string\").and.to.include(\"@\");",
              "    pm.expect(responseJson.username).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.test(\"Nested profile objects exist\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.address).to.be.an(\"object\");",
              "    pm.expect(responseJson.hair).to.be.an(\"object\");",
              "    pm.expect(responseJson.company).to.be.an(\"object\");",
              "    pm.expect(responseJson.bank).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"Address structure contains required fields\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.address).to.have.property(\"address\");",
              "    pm.expect(responseJson.address).to.have.property(\"city\");",
              "    pm.expect(responseJson.address).to.have.property(\"state\");",
              "    pm.expect(responseJson.address).to.have.property(\"coordinates\");",
              "    pm.expect(responseJson.address.coordinates.lat).to.be.a(\"number\");",
              "    pm.expect(responseJson.address.coordinates.lng).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Hair and company structures are populated\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.hair.color).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.hair.type).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.company.name).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.company.title).to.be.a(\"string\").and.not.empty;",
              "});",
              "",
              "pm.test(\"Image and birthDate fields are well-formed\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.image).to.be.a(\"string\").and.match(/^https?:\\/\\//);",
              "    pm.expect(responseJson.birthDate).to.be.a(\"string\").and.match(/^\\d{4}-\\d{1,2}-\\d{1,2}$/);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/auth/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      },
      "response": []
