    {
      "name": "Get Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson = {};",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is under 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Content-Type header is JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"Response has valid JSON\", function () {",
              "    responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"Products response contains collection metadata\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson).to.have.property(\"products\");",
              "    pm.expect(responseJson.products).to.be.an(\"array\").that.is.not.empty;",
              "    pm.expect(responseJson).to.have.property(\"total\");",
              "    pm.expect(responseJson).to.have.property(\"skip\");",
              "    pm.expect(responseJson).to.have.property(\"limit\");",
              "});",
              "",
              "pm.test(\"Pagination fields have numeric values\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.total).to.be.a(\"number\");",
              "    pm.expect(responseJson.skip).to.be.a(\"number\");",
              "    pm.expect(responseJson.limit).to.be.a(\"number\");",
              "    pm.expect(responseJson.total).to.be.at.least(responseJson.products.length);",
              "});",
              "",
              "pm.test(\"First product contains required fields\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    const product = responseJson.products[0];",
              "    pm.expect(product).to.have.property(\"id\");",
              "    pm.expect(product).to.have.property(\"title\");",
              "    pm.expect(product).to.have.property(\"price\");",
              "    pm.expect(product).to.have.property(\"category\");",
              "    pm.expect(product).to.have.property(\"stock\");",
              "});",
              "",
              "pm.test(\"First product field types are correct\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    const product = responseJson.products[0];",
              "    pm.expect(product.id).to.be.a(\"number\");",
              "    pm.expect(product.title).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(product.price).to.be.a(\"number\");",
              "    pm.expect(product.category).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(product.stock).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"First product nested structures are valid\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    const product = responseJson.products[0];",
              "    pm.expect(product.tags).to.be.an(\"array\");",
              "    pm.expect(product.dimensions).to.be.an(\"object\");",
              "    pm.expect(product.dimensions.width).to.be.a(\"number\");",
              "    pm.expect(product.dimensions.height).to.be.a(\"number\");",
              "    pm.expect(product.dimensions.depth).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Save first product_id to environment\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    const productId = responseJson?.products?.[0]?.id;",
              "    pm.expect(productId).to.not.equal(undefined);",
              "    pm.environment.set(\"product_id\", productId);",
              "    console.log(\"product_id:\", productId);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
