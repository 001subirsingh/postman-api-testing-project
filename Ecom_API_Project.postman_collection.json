        {
          "listen": "test",
          "script": {
            "exec": [
              "let responseJson;",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is under 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Content-Type header is JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"Response has valid JSON\", function () {",
              "    responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an(\"object\");",
              "});",
              "",
              "pm.test(\"Returned product has required fields\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson).to.have.property(\"id\");",
              "    pm.expect(responseJson).to.have.property(\"title\");",
              "    pm.expect(responseJson).to.have.property(\"description\");",
              "    pm.expect(responseJson).to.have.property(\"price\");",
              "    pm.expect(responseJson).to.have.property(\"category\");",
              "    pm.expect(responseJson).to.have.property(\"stock\");",
              "});",
              "",
              "pm.test(\"Returned product field types are correct\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.id).to.be.a(\"number\");",
              "    pm.expect(responseJson.title).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.description).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.price).to.be.a(\"number\");",
              "    pm.expect(responseJson.stock).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Path variable product_id matches response id when numeric\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    const requestedId = pm.variables.get(\"product_id\");",
              "    pm.expect(requestedId, \"product_id variable should exist\").to.exist;",
              "    pm.expect(String(responseJson.id)).to.eql(String(requestedId));",
              "});",
              "",
              "pm.test(\"Product media and categorization fields are valid\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.category).to.be.a(\"string\").and.not.empty;",
              "    pm.expect(responseJson.image || responseJson.thumbnail).to.be.a(\"string\");",
              "    pm.expect(responseJson.tags).to.be.an(\"array\");",
              "});",
              "",
              "pm.test(\"Product dimensions structure is valid\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.dimensions).to.be.an(\"object\");",
              "    pm.expect(responseJson.dimensions.width).to.be.a(\"number\");",
              "    pm.expect(responseJson.dimensions.height).to.be.a(\"number\");",
              "    pm.expect(responseJson.dimensions.depth).to.be.a(\"number\");",
              "});",
              "",
              "pm.test(\"Ratings and reviews structure is valid when present\", function () {",
              "    responseJson = responseJson || pm.response.json();",
              "    pm.expect(responseJson.rating).to.be.a(\"number\");",
              "    pm.expect(responseJson.reviews).to.be.an(\"array\");",
              "    if (responseJson.reviews.length > 0) {",
              "        pm.expect(responseJson.reviews[0]).to.have.property(\"rating\");",
              "        pm.expect(responseJson.reviews[0]).to.have.property(\"comment\");",
              "        pm.expect(responseJson.reviews[0].rating).to.be.a(\"number\");",
              "    }",
              "});"
